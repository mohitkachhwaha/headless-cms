// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id
  name                 String
  email                String               @unique
  password             String
  role                 String               @default("user")
  avatar               String?
  bio                  String?
  isActive             Int                  @default(1)
  createdAt            Int
  updatedAt            Int
  posts                Post[]
  pages                Page[]
  comments             Comment[]
  sessions             Session[]
  passwordResetTokens  PasswordResetToken[]
  courses              Course[]
  courseOrders         CourseOrder[]
  media                Media[]
  webStories           WebStory[]

  @@index([createdAt])
  @@index([email])
}

model Session {
  id        String   @id
  userId    String
  token     String
  expiresAt Int
  createdAt Int
  updatedAt Int
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt Int
  createdAt Int
  updatedAt Int
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Post {
  id            String     @id
  title         String
  slug          String     @unique
  content       String?
  excerpt       String?
  status        String     @default("draft")
  authorId      String
  categoryId    String?
  tags          String?    // JSON string
  featuredImage String?
  publishedAt   Int?
  createdAt     Int
  updatedAt     Int
  author        User       @relation(fields: [authorId], references: [id])
  category      Category?  @relation(fields: [categoryId], references: [id])
  comments      Comment[]

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([createdAt])
}

model Page {
  id            String     @id
  title         String
  slug          String     @unique
  content       String?
  status        String     @default("draft")
  authorId      String
  parentId      String?
  menuOrder     Int?
  featuredImage String?
  publishedAt   Int?
  createdAt     Int
  updatedAt     Int
  author        User       @relation(fields: [authorId], references: [id])
  parent        Page?      @relation("PageHierarchy", fields: [parentId], references: [id])
  children      Page[]     @relation("PageHierarchy")
  comments      Comment[]

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([createdAt])
}

model Category {
  id          String     @id
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  createdAt   Int
  updatedAt   Int
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  posts       Post[]
  courses     Course[]

  @@index([slug])
  @@index([createdAt])
}

model Tag {
  id          String   @id
  name        String
  slug        String   @unique
  description String?
  createdAt   Int
  updatedAt   Int

  @@index([slug])
  @@index([createdAt])
}

model Media {
  id         String   @id
  filename   String
  url        String
  alt        String?
  type       String
  size       Int
  uploadedBy String
  createdAt  Int
  updatedAt  Int
  user       User     @relation(fields: [uploadedBy], references: [id])

  @@index([uploadedBy])
  @@index([createdAt])
}

model Comment {
  id        String     @id
  postId    String?
  pageId    String?
  authorId  String?
  content   String
  status    String     @default("pending")
  parentId  String?
  createdAt Int
  updatedAt Int
  post      Post?      @relation(fields: [postId], references: [id])
  page      Page?      @relation(fields: [pageId], references: [id])
  author    User?      @relation(fields: [authorId], references: [id])
  parent    Comment?   @relation("CommentHierarchy", fields: [parentId], references: [id])
  children  Comment[]  @relation("CommentHierarchy")

  @@index([postId])
  @@index([pageId])
  @@index([authorId])
  @@index([status])
  @@index([createdAt])
}

model Menu {
  id        String   @id
  name      String
  location  String
  items     String   // JSON string
  createdAt Int
  updatedAt Int

  @@index([location])
  @@index([createdAt])
}

model Redirect {
  id          String   @id
  fromUrl     String   @unique
  toUrl       String
  statusCode  Int      @default(301)
  createdAt   Int
  updatedAt   Int

  @@index([fromUrl])
  @@index([createdAt])
}

model SeoSetting {
  id            String   @id
  pageType      String
  pageId        String
  title         String?
  description   String?
  keywords      String?
  ogImage       String?
  canonicalUrl  String?
  noIndex       Int      @default(0)
  noFollow      Int      @default(0)
  createdAt     Int
  updatedAt     Int

  @@index([pageType])
  @@index([pageId])
  @@index([createdAt])
}

model CmsSetting {
  id        String   @id
  key       String   @unique
  value     String
  type      String
  group     String
  createdAt Int
  updatedAt Int

  @@index([key])
  @@index([group])
  @@index([createdAt])
}

model Ad {
  id          String   @id
  title       String
  content     String?
  position    String
  status      String   @default("inactive")
  startDate   Int?
  endDate     Int?
  createdAt   Int
  updatedAt   Int

  @@index([position])
  @@index([status])
  @@index([createdAt])
}

model Backup {
  id          String   @id
  name        String
  type        String
  filePath    String
  size        Int
  status      String   @default("pending")
  createdAt   Int
  updatedAt   Int

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model WebStory {
  id          String   @id
  title       String
  slug        String   @unique
  content     String   // JSON string
  status      String   @default("draft")
  authorId    String
  publishedAt Int?
  createdAt   Int
  updatedAt   Int
  author      User     @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([createdAt])
}

model Course {
  id            String       @id
  title         String
  slug          String       @unique
  description   String?
  content       String?
  price         Float
  currency      String       @default("USD")
  status        String       @default("draft")
  authorId      String
  categoryId    String?
  tags          String?      // JSON string
  featuredImage String?
  publishedAt   Int?
  createdAt     Int
  updatedAt     Int
  author        User         @relation(fields: [authorId], references: [id])
  category      Category?    @relation(fields: [categoryId], references: [id])
  courseOrders  CourseOrder[]

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([createdAt])
}

model CourseOrder {
  id        String   @id
  courseId  String
  userId    String
  amount    Float
  currency  String
  status    String   @default("pending")
  paymentId String?
  createdAt Int
  updatedAt Int
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([courseId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}
